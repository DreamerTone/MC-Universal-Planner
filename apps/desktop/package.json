{
  "name": "@mc-planner/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop application shell for MC Universal Planner",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electronmon dist/electron/main.js\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@mc-planner/asset-pipeline": "workspace:*",
    "@mc-planner/ecs": "workspace:*",
    "@mc-planner/renderer-core": "workspace:*",
    "@mc-planner/serialization": "workspace:*",
    "@mc-planner/shared": "workspace:*",
    "@mc-planner/simulation-engine": "workspace:*",
    "@mc-planner/world-engine": "workspace:*",
    "electron-store": "^10.0.0",
    "three": "^0.164.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.164.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electronmon": "^2.0.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vite-plugin-electron": "^0.28.0"
  }
}
