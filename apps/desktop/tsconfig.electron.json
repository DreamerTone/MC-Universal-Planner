{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist/electron",
    "target": "ES2022",
    "lib": ["ES2022"],
    "verbatimModuleSyntax": false
  },
  "include": ["electron/**/*", "preload/**/*"],
  "exclude": ["node_modules", "dist", "renderer"]
}
